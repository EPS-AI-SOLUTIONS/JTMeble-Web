{
  "name": "jtmeble-web",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':!*.md' ':!docs/' ':!.github/' ':!scripts/' ':!.claude' 2>/dev/null || exit 1"
}
